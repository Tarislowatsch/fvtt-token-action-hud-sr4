{
  "id": "token-action-hud-sr4",
  "title": "Token Action HUD - Shadowrun 4e",
  "description": "Token Action HUD integration for the Shadowrun 4th Edition system.",
  "version": "1.2.0",
  "manifest": "https://raw.githubusercontent.com/tarislowatsch/tvtt-token-action-hud-sr4/main/module.json",
